# URL мини-приложений — ОБЯЗАТЕЛЬНО настройте! Иначе откроется реклама/404.
# Скопируйте в .env и замените на ваши URL.

# === ЛОКАЛЬНОЕ ТЕСТИРОВАНИЕ (ngrok) ===
# 1. Запустите приложение в одном терминале
# 2. В другом: ngrok http ПОРТ
# 3. Скопируйте https://xxx.ngrok-free.app сюда

# Клиент - YATAPPAI: npm run web (порт 8081), затем ngrok http 8081
CLIENT_APP_URL=https://xxxx.ngrok-free.app

# Курьер - DELIVERY: npm run web (порт 8081), затем ngrok http 8081
COURIER_APP_URL=https://xxxx.ngrok-free.app

# Панель ресторанов: npm run dashboard (порт 3003), затем ngrok http 3003
RESTAURANT_PANEL_URL=https://xxxx.ngrok-free.app

# Панель курьеров: npm run courier-panel (порт 3005), затем ngrok http 3005
COURIER_COMPANY_PANEL_URL=https://xxxx.ngrok-free.app

