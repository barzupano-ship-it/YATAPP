# SQLite (local dev) - no setup needed
DATABASE_URL=file:./dev.db

# Or PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/yatapp
PORT=3002
JWT_SECRET="change-me-in-production"
CORS_ORIGIN="*"
# Email that gets superadmin access to admin panel (default: barzupano@gmail.com)
SUPERADMIN_EMAIL=barzupano@gmail.com
